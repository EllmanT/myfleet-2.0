# Copy this file to .env in the same directory (backend/config/)
# Start the API with cwd = backend/ so dotenv loads this file.

# Server
PORT=5050

# MongoDB — Database.js uses OFFLINE_DB_URL when NODE_ENV is not "production"
OFFLINE_DB_URL=mongodb://127.0.0.1:27017/myfleet

# MongoDB — used when NODE_ENV=production (lowercase)
# DB_URL=mongodb+srv://user:pass@cluster.example.mongodb.net/myfleet

# --- Vercel (production) ---
# NODE_ENV is set to production by Vercel. Set these in Project → Settings → Environment Variables:

# Secrets (mirror backend vars above — use MongoDB Atlas URI for DB_URL; allow 0.0.0.0/0 unless using Vercel IPs)
# DB_URL=

# Frontend origin(s) — required if the React app is hosted on a different origin than the API
# FRONTEND_URL=https://your-app.vercel.app
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# CRA build-time: usually omit so the app uses `/api/v2` on the same hostname as the SPA
# REACT_APP_API_ORIGIN=

# Forgot-password dev shortcut — never set true in production
# RESET_PASSWORD_DEV_LINK=


# Seed pipeline (used by `npm run seed`)
# Local stage target (defaults to OFFLINE_DB_URL if omitted)
# MONGO_URI_LOCAL=mongodb://127.0.0.1:27017/myfleet
# Live stage target (defaults to DB_URL if omitted)
# MONGO_URI_LIVE=mongodb+srv://user:pass@cluster.example.mongodb.net/myfleet
# Backup directory (JSON exports). Default in code: repo root ./db-backup-2026-04-18
# SEED_BACKUP_DIR=../db-backup-2026-04-18

# Auth (JWT in httpOnly cookie)
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_EXPIRES=7d

# Email activation token signing
ACTIVATION_SECRET=change-me-activation-secret

# Public URL of the React app (password reset links in email)
FRONTEND_URL=http://localhost:3000

# Local dev only: forgot-password returns JSON devResetUrl when SMTP is not configured (omit in production)
# RESET_PASSWORD_DEV_LINK=true

# Nodemailer — variable names use SMPT_* as in backend/utils/sendMail.js
# SMPT_HOST=smtp.example.com
# SMPT_PORT=587
# SMPT_SERVICE=
# SMPT_MAIL=noreply@example.com
# SMPT_PASSWORD=

# Optional: dotenv is skipped when NODE_ENV is PRODUCTION (all caps) in server.js/app.js
# NODE_ENV=
