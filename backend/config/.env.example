# Copy this file to .env in the same directory (backend/config/)
# Start the API with cwd = backend/ so dotenv loads this file.

# Server
PORT=5050

# MongoDB — Database.js uses OFFLINE_DB_URL when NODE_ENV is not "production"
OFFLINE_DB_URL=mongodb://127.0.0.1:27017/myfleet

# MongoDB — used when NODE_ENV=production (lowercase)
# DB_URL=mongodb+srv://user:pass@cluster.example.mongodb.net/myfleet

# Auth (JWT in httpOnly cookie)
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_EXPIRES=7d

# Email activation token signing
ACTIVATION_SECRET=change-me-activation-secret

# Nodemailer — variable names use SMPT_* as in backend/utils/sendMail.js
# SMPT_HOST=smtp.example.com
# SMPT_PORT=587
# SMPT_SERVICE=
# SMPT_MAIL=noreply@example.com
# SMPT_PASSWORD=

# Optional: dotenv is skipped when NODE_ENV is PRODUCTION (all caps) in server.js/app.js
# NODE_ENV=
